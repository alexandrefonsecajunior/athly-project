// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SportType {
  running
  cycling
  swimming
  strength
  crossfit
  triathlon
  duathlon
  yoga
  walking
  other
}

enum TrainingPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  LOCKED
  DRAFT
}

enum WorkoutStatus {
  scheduled
  done
  skipped
  partial
}

enum IntegrationType {
  strava
  garmin
  apple_health
  other
}

enum RoleEnum {
  STANDARD
  PREMIUM
  ADMIN
}

enum WeeklyGoalStatus {
  PLANNED
  GENERATED
  CANCELLED
  LOCKED
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  username             String    @unique
  email                String    @unique
  password             String
  role                 RoleEnum  @default(STANDARD)
  dateOfBirth          DateTime? @map("date_of_birth")
  weight               Float?
  height               Float?
  goals                String[]
  availableDays        String[]  @default([]) @map("available_days")
  imc                  Float?
  assessmentCompleted  Boolean   @default(false) @map("assessment_completed")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  sessions      Session[]
  workouts      Workout[]
  feedback      WorkoutFeedback[]
  trainingPlans TrainingPlan[]
  integrations  Integration[]
  equipments    UserEquipment[]
  assessment    Assessment?
  effortZones   UserEffortZone[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("sessions")
}

model Workout {
  id             String        @id @default(uuid())
  trainingPlanId String        @map("training_plan_id")
  weeklyGoalId   String?       @map("weekly_goal_id")
  dateScheduled  DateTime      @map("date_scheduled")
  sportType      SportType     @map("sport_type")
  title          String
  description    String?
  blocks         Json
  status           WorkoutStatus
  intensity        Int?
  stravaActivityId String?       @unique @map("strava_activity_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan TrainingPlan      @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  weeklyGoal   WeeklyGoal?       @relation(fields: [weeklyGoalId], references: [id], onDelete: Cascade)
  userId       String            @map("user_id")
  feedback     WorkoutFeedback[]
  aiReasoning  AiReasoning?

  @@map("workouts")
}

model TrainingPlan {
  id           String             @id @default(uuid())
  startDate    String
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  objective    String
  targetDate   DateTime?          @map("target_date")
  sports       SportType[]        @map("sports")
  autoGenerate Boolean            @default(false) @map("auto_generate")
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String             @unique @map("user_id")
  weeklyGoals  WeeklyGoal[]
  status       TrainingPlanStatus @default(DRAFT) @map("status")
  workouts     Workout[]

  @@map("training_plans")
}

model WorkoutFeedback {
  id        String   @id @default(uuid())
  completed Boolean
  effort    Int
  fatigue   Int
  createdAt DateTime @default(now()) @map("created_at")

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String  @map("user_id")
  workout   Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId String  @map("workout_id")

  @@map("workout_feedbacks")
}

model Integration {
  id              String          @id @default(uuid())
  name            String
  icon            String
  connected       Boolean         @default(false)
  type            IntegrationType
  accessToken     String?         @map("access_token")
  refreshToken    String?         @map("refresh_token")
  tokenExpiresAt  DateTime?       @map("token_expires_at")
  stravaAthleteId String?         @map("strava_athlete_id")
  scope           String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("integrations")
}

model Equipment {
  uuid      String   @id @default(uuid())
  name      String
  imagePath String   @map("image_path")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userEquipments UserEquipment[]

  @@map("equipments")
}

model UserEquipment {
  userId      String   @map("user_id")
  equipmentId String   @map("equipment_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [uuid], onDelete: Cascade)

  @@id([userId, equipmentId])
  @@map("user_equipments")
}

model WeeklyGoal {
  id             String           @id @default(uuid())
  trainingPlanId String           @map("training_plan_id")
  weekStartDate  DateTime         @map("week_start_date")
  weekEndDate    DateTime         @map("week_end_date")
  status         WeeklyGoalStatus @default(PLANNED)
  metrics              Json             @map("metrics")
  previousWeekAnalysis Json?            @map("previous_week_analysis")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  createdAt            DateTime         @default(now()) @map("created_at")

  trainingPlan TrainingPlan  @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  workouts     Workout[]
  aiReasonings AiReasoning[]

  @@map("weekly_goals")
}

model Assessment {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  answers   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model UserEffortZone {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  vdotScore         Float?   @map("vdot_score")
  maxHeartRate      Int?     @map("max_heart_rate")
  restHeartRate     Int?     @map("rest_heart_rate")
  dataSource        String   @map("data_source")
  easyPaceMin       Int      @map("easy_pace_min")
  easyPaceMax       Int      @map("easy_pace_max")
  marathonPaceMin   Int      @map("marathon_pace_min")
  marathonPaceMax   Int      @map("marathon_pace_max")
  thresholdPaceMin  Int      @map("threshold_pace_min")
  thresholdPaceMax  Int      @map("threshold_pace_max")
  intervalPaceMin   Int      @map("interval_pace_min")
  intervalPaceMax   Int      @map("interval_pace_max")
  repetitionPaceMin Int      @map("repetition_pace_min")
  repetitionPaceMax Int      @map("repetition_pace_max")
  hrZones           Json?    @map("hr_zones")
  calculatedFrom    Json     @map("calculated_from")
  validUntil        DateTime @map("valid_until")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_effort_zones")
}

model AiReasoning {
  id             String     @id @default(uuid())
  workoutId      String     @unique @map("workout_id")
  weeklyGoalId   String     @map("weekly_goal_id")
  justification  String
  dataPointsUsed Json       @map("data_points_used")
  promptVersion  String     @map("prompt_version")
  modelUsed      String     @map("model_used")
  createdAt      DateTime   @default(now()) @map("created_at")

  workout    Workout    @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  weeklyGoal WeeklyGoal @relation(fields: [weeklyGoalId], references: [id], onDelete: Cascade)

  @@map("ai_reasonings")
}
