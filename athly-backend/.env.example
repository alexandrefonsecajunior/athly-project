# JWT
JWT_SECRET="seu_secret_super_seguro_aqui_mude_em_producao"
JWT_EXPIRES_IN="1h"

# Server
PORT=4000

# Strava OAuth — obrigatório para integração com Strava
# Crie seu app em: https://www.strava.com/settings/api
STRAVA_CLIENT_ID="seu_strava_client_id"
STRAVA_CLIENT_SECRET="seu_strava_client_secret"
# URL para onde o Strava redireciona após autorização (deve bater com o cadastro no app Strava)
STRAVA_REDIRECT_URI="http://localhost:5173/oauth/strava/callback"

# Google Gemini API Key
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="sua_gemini_api_key"

# Redis (opcional — usado para cache de respostas da IA)
REDIS_URL=redis://localhost:6379

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=iafit
DATABASE_URL="postgresql://user:password@localhost:5432/iafit"
